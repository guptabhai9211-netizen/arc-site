"use client";

import { useState, useEffect, useRef } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { Link, useLocation } from "react-router-dom";
import { 
  FaHome, 
  FaBook, 
  FaInfoCircle, 
  FaEnvelope, 
  FaUserGraduate, 
  FaBars, 
  FaTimes,
  FaChevronDown,
  FaLaptopCode,
  FaSignInAlt,
  FaUser,
  FaLock,
  FaTimesCircle,
  FaBlog,
  FaSun,
  FaMoon,
  FaPhoneAlt,
  FaWhatsapp,
  FaMapMarkerAlt,
  FaClock,
  FaAward,
  FaRocket,
  FaShieldAlt,
  FaUsers,
  FaStar,
  FaGraduationCap
} from "react-icons/fa";

const Navbar = () => {
  const [isOpen, setIsOpen] = useState(false);
  const [scrolled, setScrolled] = useState(false);
  const [contactDropdownOpen, setContactDropdownOpen] = useState(false);
  const [showLoginModal, setShowLoginModal] = useState(false);
  const [loginEmail, setLoginEmail] = useState("");
  const [loginPassword, setLoginPassword] = useState("");
  const [loginError, setLoginError] = useState("");
  const [isLoggedIn, setIsLoggedIn] = useState(false);
  const [userName, setUserName] = useState("");
  const [isDarkMode, setIsDarkMode] = useState(false);
  const [showNotification, setShowNotification] = useState(false);
  const [notificationMessage, setNotificationMessage] = useState("");
  const [notificationAction, setNotificationAction] = useState(null);
  const [previousTheme, setPreviousTheme] = useState(null);
  const location = useLocation();
  const contactDropdownRef = useRef(null);
  const loginModalRef = useRef(null);
  const mobileMenuRef = useRef(null);

  const navLinks = [
    { name: "Home", path: "/", icon: FaHome },
    { name: "Courses", path: "/courses", icon: FaBook },
    { name: "About", path: "/about", icon: FaInfoCircle },
    { name: "Blog", path: "/blog", icon: FaBlog },
    { name: "Contact", path: "/contactSection", icon: FaEnvelope, hasDropdown: true },
  ];

  const contactSteps = [
    { step: "1", title: "Apply Now", description: "WhatsApp us, fill the contact form, visit our branches, or call 8860448368", icon: FaUserGraduate },
    { step: "2", title: "Counseling Session", description: "Free career counseling to choose the right course", icon: FaUserGraduate },
    { step: "3", title: "Registration", description: "Complete registration with minimal fee", icon: FaBook },
    { step: "4", title: "Start Learning", description: "Begin your journey with expert trainers", icon: FaLaptopCode },
  ];

  const quickLinks = [
    { icon: FaWhatsapp, label: "WhatsApp", value: "8860448368", color: "text-green-500" },
    { icon: FaPhoneAlt, label: "Call Us", value: "8860448368", color: "text-blue-500" },
    { icon: FaMapMarkerAlt, label: "Location", value: "ARC Institute", color: "text-red-500" },
    { icon: FaClock, label: "Timing", value: "9 AM - 8 PM", color: "text-purple-500" },
  ];

  const stats = [
    { icon: FaUsers, value: "5000+", label: "Students" },
    { icon: FaAward, value: "50+", label: "Courses" },
    { icon: FaStar, value: "4.9", label: "Rating" },
    { icon: FaGraduationCap, value: "98%", label: "Placement" },
  ];

  const applyTheme = (theme) => {
    const isDark = theme === "dark";
    setIsDarkMode(isDark);
    document.documentElement.classList.toggle("dark", isDark);
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("arcTheme", theme);
  };

  const notify = (message, action = null) => {
    setNotificationMessage(message);
    setNotificationAction(action);
    setShowNotification(true);
    window.clearTimeout(window.__arcNotificationTimer);
    window.__arcNotificationTimer = window.setTimeout(() => {
      setShowNotification(false);
      setNotificationAction(null);
    }, action ? 6000 : 3000);
  };

  // Check for saved theme preference on mount
  useEffect(() => {
    const savedTheme = localStorage.getItem("arcTheme") || "light";
    applyTheme(savedTheme);
  }, []);

  // Toggle dark/light mode
  const toggleTheme = () => {
    const currentTheme = isDarkMode ? "dark" : "light";
    const nextTheme = isDarkMode ? "light" : "dark";
    setPreviousTheme(currentTheme);
    applyTheme(nextTheme);
    notify(`${nextTheme === "dark" ? "Dark" : "Light"} theme applied`, "undo-theme");
  };

  const undoThemeChange = () => {
    if (!previousTheme) return;
    applyTheme(previousTheme);
    setPreviousTheme(null);
    setShowNotification(false);
    setNotificationAction(null);
  };

  // Handle scroll effect
  useEffect(() => {
    const handleScroll = () => {
      setScrolled(window.scrollY > 20);
    };
    window.addEventListener("scroll", handleScroll);
    return () => window.removeEventListener("scroll", handleScroll);
  }, []);

  // Handle click outside dropdowns
  useEffect(() => {
    const handleClickOutside = (event) => {
      if (contactDropdownRef.current && !contactDropdownRef.current.contains(event.target)) {
        setContactDropdownOpen(false);
      }
      if (loginModalRef.current && !loginModalRef.current.contains(event.target)) {
        setShowLoginModal(false);
        setLoginError("");
      }
      if (mobileMenuRef.current && !mobileMenuRef.current.contains(event.target) && isOpen) {
        setIsOpen(false);
      }
    };
    document.addEventListener("mousedown", handleClickOutside);
    return () => document.removeEventListener("mousedown", handleClickOutside);
  }, [isOpen]);

  useEffect(() => {
    setIsOpen(false);
    setContactDropdownOpen(false);
  }, [location.pathname]);

  useEffect(() => {
    document.body.style.overflow = isOpen ? "hidden" : "";
    return () => {
      document.body.style.overflow = "";
    };
  }, [isOpen]);

  // Check if user is already logged in
  useEffect(() => {
    const storedUser = localStorage.getItem("arcInstituteUser");
    if (storedUser) {
      const user = JSON.parse(storedUser);
      setIsLoggedIn(true);
      setUserName(user.name);
    }
  }, []);

  const isActive = (path) => location.pathname === path;

  // Login Handler
  const handleLogin = (e) => {
    e.preventDefault();
    setLoginError("");
    
    const demoCredentials = {
      email: "student@arc.com",
      password: "student123"
    };

    if (loginEmail === demoCredentials.email && loginPassword === demoCredentials.password) {
      const userData = {
        name: "Student User",
        email: loginEmail,
        loginTime: new Date().toISOString()
      };
      localStorage.setItem("arcInstituteUser", JSON.stringify(userData));
      setIsLoggedIn(true);
      setUserName(userData.name);
      setShowLoginModal(false);
      setLoginEmail("");
      setLoginPassword("");
      setLoginError("");
      setNotificationMessage("Welcome back, Student! 🎉");
      setShowNotification(true);
      setTimeout(() => setShowNotification(false), 3000);
    } else {
      setLoginError("Invalid email or password. Use student@arc.com / student123");
    }
  };

  // Logout Handler
  const handleLogout = () => {
    localStorage.removeItem("arcInstituteUser");
    setIsLoggedIn(false);
    setUserName("");
    setNotificationMessage("You have been logged out. 👋");
    setShowNotification(true);
    setTimeout(() => setShowNotification(false), 3000);
  };

  const containerVariants = {
    hidden: { opacity: 0 },
    visible: {
      opacity: 1,
      transition: { staggerChildren: 0.05, delayChildren: 0.1 },
    },
  };

  const itemVariants = {
    hidden: { y: -20, opacity: 0 },
    visible: {
      y: 0,
      opacity: 1,
      transition: { type: "spring", stiffness: 300, damping: 24 },
    },
  };

  const mobileVariants = {
    open: { 
      opacity: 1, 
      x: 0, 
      transition: { type: "spring", stiffness: 260, damping: 28 } 
    },
    closed: { 
      opacity: 0, 
      x: "100%", 
      transition: { type: "spring", stiffness: 260, damping: 28 } 
    },
  };

  return (
    <>
      <nav className={`fixed top-0 w-full z-50 transition-all duration-500 ${
        scrolled 
          ? isDarkMode ? "bg-gray-900/95 backdrop-blur-xl shadow-2xl py-1" : "bg-white/95 backdrop-blur-xl shadow-2xl py-1"
          : isDarkMode ? "bg-gray-900/90 backdrop-blur-md shadow-lg py-2" : "bg-white/90 backdrop-blur-md shadow-lg py-2"
      }`}>
        
        {/* Top Bar - Quick Info */}
        <div className={`hidden lg:block border-b transition-colors duration-300 ${
          isDarkMode ? "border-gray-800" : "border-gray-100"
        }`}>
          <div className="container mx-auto px-4 py-1.5">
            <div className="flex justify-between items-center text-xs">
              <div className="flex items-center gap-6">
                {quickLinks.map((item, index) => {
                  const Icon = item.icon;
                  return (
                    <div key={index} className="flex items-center gap-2">
                      <Icon className={`${item.color} text-sm`} />
                      <span className={isDarkMode ? "text-gray-400" : "text-gray-600"}>{item.label}:</span>
                      <span className={isDarkMode ? "text-gray-300 font-medium" : "text-gray-700 font-medium"}>{item.value}</span>
                    </div>
                  );
                })}
              </div>
              <div className="flex items-center gap-4">
                {stats.map((stat, index) => {
                  const Icon = stat.icon;
                  return (
                    <div key={index} className="flex items-center gap-1.5">
                      <Icon className={isDarkMode ? "text-blue-400" : "text-blue-600"} />
                      <span className={isDarkMode ? "text-white font-bold" : "text-gray-800 font-bold"}>{stat.value}</span>
                      <span className={isDarkMode ? "text-gray-400" : "text-gray-500"}>{stat.label}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </div>

        {/* Main Nav */}
        <div className="container mx-auto px-3 sm:px-4 lg:px-8">
          <div className="flex justify-between items-center">
            {/* Logo Section */}
            <motion.div
              initial={{ opacity: 0, x: -30 }}
              animate={{ opacity: 1, x: 0 }}
              transition={{ duration: 0.5, type: "spring" }}
              className="flex items-center group cursor-pointer flex-shrink-0"
            >
              <Link to="/" className="flex items-center gap-2 sm:gap-3 cursor-pointer">
                <div className="relative cursor-pointer">
                  <div className="absolute inset-0 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full blur-xl opacity-50 group-hover:opacity-75 transition duration-500" />
                  <div className="absolute inset-0 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full blur-2xl opacity-20 group-hover:opacity-40 transition duration-500" />
                  <img
                    src="/logo.jpg"
                    alt="ARC Computer Institute"
                    className="h-10 w-10 sm:h-12 sm:w-12 rounded-full relative z-10 transition-all duration-500 group-hover:scale-110 group-hover:rotate-6 cursor-pointer object-cover border-2 border-blue-500/20 shadow-lg"
                    onError={(e) => { e.target.src = "https://via.placeholder.com/48x48?text=ARC"; }}
                  />
                </div>
                <div className="flex flex-col cursor-pointer">
                  <h1 className={`text-sm sm:text-base md:text-xl lg:text-2xl font-extrabold bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 bg-clip-text text-transparent leading-tight cursor-pointer tracking-tight`}>
                    <span className="hidden sm:inline">ARC Computer Institute</span>
                    <span className="inline sm:hidden">ARC</span>
                  </h1>
                  <p className={`text-[10px] sm:text-xs ${isDarkMode ? 'text-gray-400' : 'text-gray-500'} hidden sm:block cursor-pointer tracking-wider`}>🎓 Innovate • Code • Succeed</p>
                </div>
              </Link>
            </motion.div>

            {/* Desktop Navigation */}
            <motion.div
              className="hidden lg:flex items-center space-x-1"
              variants={containerVariants}
              initial="hidden"
              animate="visible"
            >
              {navLinks.map((link) => {
                const Icon = link.icon;
                
                if (link.hasDropdown && link.name === "Contact") {
                  return (
                    <motion.div
                      key={link.name}
                      className="relative"
                      variants={itemVariants}
                      ref={contactDropdownRef}
                    >
                      <button
                        onClick={() => setContactDropdownOpen(!contactDropdownOpen)}
                        onMouseEnter={() => setContactDropdownOpen(true)}
                        className={`flex items-center gap-1 xl:gap-2 px-3 xl:px-4 py-2 text-xs xl:text-sm font-medium rounded-xl transition-all duration-300 cursor-pointer whitespace-nowrap relative group ${
                          isActive(link.path)
                            ? "text-blue-600 bg-blue-50/80 dark:bg-blue-900/30 dark:text-blue-400"
                            : isDarkMode 
                              ? "text-gray-300 hover:text-white hover:bg-gray-800/80" 
                              : "text-gray-700 hover:text-blue-600 hover:bg-blue-50/80"
                        }`}
                      >
                        <span className="absolute inset-0 rounded-xl bg-gradient-to-r from-blue-500/0 via-blue-500/0 to-purple-500/0 group-hover:from-blue-500/10 group-hover:via-blue-500/5 group-hover:to-purple-500/10 transition-all duration-500" />
                        <Icon className="text-sm xl:text-base relative z-10" />
                        <span className="hidden xl:inline relative z-10">{link.name}</span>
                        <span className="xl:hidden inline relative z-10">Contact</span>
                        <FaChevronDown className={`text-[10px] xl:text-xs transition-transform duration-300 relative z-10 ${contactDropdownOpen ? "rotate-180" : ""}`} />
                      </button>

                      <AnimatePresence>
                        {contactDropdownOpen && (
                          <motion.div
                            initial={{ opacity: 0, y: -10, scale: 0.95 }}
                            animate={{ opacity: 1, y: 0, scale: 1 }}
                            exit={{ opacity: 0, y: -10, scale: 0.95 }}
                            transition={{ type: "spring", stiffness: 300, damping: 30 }}
                            onMouseLeave={() => setContactDropdownOpen(false)}
                            className={`absolute top-full left-0 mt-2 w-80 xl:w-[420px] rounded-2xl shadow-2xl border overflow-hidden z-50 ${
                              isDarkMode 
                                ? "bg-gray-900/95 backdrop-blur-xl border-gray-700" 
                                : "bg-white/95 backdrop-blur-xl border-gray-200"
                            }`}
                            style={{ cursor: 'default' }}
                          >
                            <div className={`p-5 bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 text-white`}>
                              <div className="flex items-start justify-between">
                                <div>
                                  <h3 className="text-lg font-bold">Get in Touch</h3>
                                  <p className="text-blue-100 text-sm mt-1">We're here to help you!</p>
                                </div>
                                <div className="bg-white/20 rounded-lg p-2">
                                  <FaPhoneAlt className="text-white text-lg" />
                                </div>
                              </div>
                            </div>
                            <div className="p-5 space-y-3">
                              {contactSteps.map((step) => {
                                const StepIcon = step.icon;
                                return (
                                  <motion.div 
                                    key={step.step} 
                                    className="flex items-start gap-3 cursor-default group hover:bg-blue-50/50 dark:hover:bg-blue-900/20 p-2 rounded-xl transition-all duration-300"
                                    whileHover={{ x: 5 }}
                                  >
                                    <div className="flex-shrink-0 w-8 h-8 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-full flex items-center justify-center text-sm font-bold shadow-lg">
                                      {step.step}
                                    </div>
                                    <div className="flex-1">
                                      <div className="flex items-center gap-2">
                                        <StepIcon className="text-blue-600 dark:text-blue-400 text-sm" />
                                        <h4 className={`font-semibold text-sm ${isDarkMode ? 'text-white' : 'text-gray-800'}`}>{step.title}</h4>
                                      </div>
                                      <p className={`text-xs mt-1 ${isDarkMode ? 'text-gray-400' : 'text-gray-600'}`}>{step.description}</p>
                                    </div>
                                  </motion.div>
                                );
                              })}
                            </div>
                            <div className={`p-4 border-t ${isDarkMode ? 'bg-gray-800/50 border-gray-700' : 'bg-gray-50/50 border-gray-200'}`}>
                              <div className="flex gap-3">
                                <Link
                                  to="/contactSection"
                                  onClick={() => setContactDropdownOpen(false)}
                                  className="flex-1 text-center bg-gradient-to-r from-blue-600 to-purple-600 text-white py-2.5 rounded-xl text-sm font-semibold hover:shadow-lg hover:scale-[1.02] transition-all duration-300"
                                >
                                  📞 Contact Now
                                </Link>
                                <a
                                  href="https://wa.me/918860448368"
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  className="flex-1 text-center bg-green-600 text-white py-2.5 rounded-xl text-sm font-semibold hover:shadow-lg hover:scale-[1.02] transition-all duration-300"
                                >
                                  💬 WhatsApp
                                </a>
                              </div>
                            </div>
                          </motion.div>
                        )}
                      </AnimatePresence>
                    </motion.div>
                  );
                }

                return (
                  <motion.div key={link.name} variants={itemVariants}>
                    <Link
                      to={link.path}
                      className={`flex items-center gap-1 xl:gap-2 px-3 xl:px-4 py-2 text-xs xl:text-sm font-medium rounded-xl transition-all duration-300 cursor-pointer whitespace-nowrap relative group ${
                        isActive(link.path)
                          ? "text-blue-600 bg-blue-50/80 dark:bg-blue-900/30 dark:text-blue-400"
                          : isDarkMode 
                            ? "text-gray-300 hover:text-white hover:bg-gray-800/80" 
                            : "text-gray-700 hover:text-blue-600 hover:bg-blue-50/80"
                      }`}
                    >
                      <span className="absolute inset-0 rounded-xl bg-gradient-to-r from-blue-500/0 via-blue-500/0 to-purple-500/0 group-hover:from-blue-500/10 group-hover:via-blue-500/5 group-hover:to-purple-500/10 transition-all duration-500" />
                      <Icon className="text-sm xl:text-base relative z-10" />
                      <span className="relative z-10">{link.name}</span>
                      {isActive(link.path) && (
                        <motion.span
                          layoutId="activeIndicator"
                          className="absolute inset-0 rounded-xl bg-blue-500/10 dark:bg-blue-500/20"
                          transition={{ type: "spring", stiffness: 500, damping: 30 }}
                        />
                      )}
                    </Link>
                  </motion.div>
                );
              })}

              {/* Theme Toggle */}
              <motion.div variants={itemVariants} className="ml-1 xl:ml-2">
                <motion.button
                  onClick={toggleTheme}
                  className={`flex items-center justify-center w-9 h-9 xl:w-10 xl:h-10 rounded-xl transition-all duration-300 cursor-pointer relative group ${
                    isDarkMode 
                      ? "bg-gray-800 text-yellow-400 hover:bg-gray-700" 
                      : "bg-gray-100 text-gray-700 hover:bg-gray-200"
                  }`}
                  whileHover={{ scale: 1.05 }}
                  whileTap={{ scale: 0.95 }}
                  aria-label="Toggle theme"
                >
                  <span className="absolute inset-0 rounded-xl bg-gradient-to-r from-yellow-400/0 via-yellow-400/0 to-orange-400/0 group-hover:from-yellow-400/10 group-hover:via-yellow-400/5 group-hover:to-orange-400/10 transition-all duration-500" />
                  {isDarkMode ? <FaSun className="text-lg xl:text-xl relative z-10" /> : <FaMoon className="text-lg xl:text-xl relative z-10" />}
                </motion.button>
              </motion.div>

              {/* Login/User */}
              <motion.div variants={itemVariants} className="ml-1 xl:ml-2">
                {isLoggedIn ? (
                  <motion.div 
                    className="flex items-center gap-2 xl:gap-3"
                    initial={{ opacity: 0, scale: 0.8 }}
                    animate={{ opacity: 1, scale: 1 }}
                  >
                    <div className={`flex items-center gap-2 px-3 xl:px-4 py-1.5 xl:py-2 rounded-xl ${
                      isDarkMode ? "bg-green-900/30 border border-green-800/30" : "bg-green-50 border border-green-200/50"
                    }`}>
                      <div className="w-7 h-7 xl:w-8 xl:h-8 bg-gradient-to-r from-green-500 to-green-600 rounded-full flex items-center justify-center text-white font-bold text-xs xl:text-sm shadow-lg">
                        {userName.charAt(0).toUpperCase()}
                      </div>
                      <span className={`text-xs xl:text-sm font-medium hidden sm:inline ${isDarkMode ? 'text-gray-300' : 'text-gray-700'}`}>{userName}</span>
                    </div>
                    <motion.button
                      onClick={handleLogout}
                      className="px-3 xl:px-4 py-1.5 xl:py-2 bg-gradient-to-r from-red-500 to-red-600 text-white text-xs xl:text-sm font-semibold rounded-xl hover:shadow-lg hover:scale-[1.05] transition-all duration-300 cursor-pointer"
                      whileHover={{ scale: 1.05 }}
                      whileTap={{ scale: 0.95 }}
                    >
                      Logout
                    </motion.button>
                  </motion.div>
                ) : (
                  <motion.button
                    onClick={() => setShowLoginModal(true)}
                    className="flex items-center gap-1 xl:gap-2 px-3 xl:px-5 py-1.5 xl:py-2.5 bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 text-white text-xs xl:text-sm font-semibold rounded-xl shadow-lg hover:shadow-xl hover:scale-[1.05] transition-all duration-300 cursor-pointer whitespace-nowrap relative group overflow-hidden"
                    whileHover={{ scale: 1.05 }}
                    whileTap={{ scale: 0.95 }}
                  >
                    <span className="absolute inset-0 bg-gradient-to-r from-blue-600/0 via-white/20 to-purple-600/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700" />
                    <FaSignInAlt className="text-xs xl:text-base relative z-10" />
                    <span className="hidden sm:inline relative z-10">Student Login</span>
                    <span className="sm:hidden inline relative z-10">Login</span>
                  </motion.button>
                )}
              </motion.div>
            </motion.div>

            {/* Mobile Menu Button */}
            <motion.button
              onClick={() => setIsOpen(!isOpen)}
              className="lg:hidden flex items-center justify-center w-10 h-10 sm:w-11 sm:h-11 rounded-xl bg-gradient-to-r from-blue-600 to-purple-600 text-white shadow-lg cursor-pointer flex-shrink-0 relative group overflow-hidden"
              whileTap={{ scale: 0.9 }}
            >
              <span className="absolute inset-0 bg-gradient-to-r from-blue-600/0 via-white/20 to-purple-600/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700" />
              {isOpen ? <FaTimes className="text-base sm:text-xl relative z-10" /> : <FaBars className="text-base sm:text-xl relative z-10" />}
            </motion.button>
          </div>
        </div>

      </nav>

      {/* Mobile Navigation - Premium */}
        <AnimatePresence>
          {isOpen && (
            <>
              <motion.div
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="fixed inset-0 bg-black/60 backdrop-blur-sm z-[80] lg:hidden"
                onClick={() => setIsOpen(false)}
              />
              
              <motion.div
                ref={mobileMenuRef}
                initial="closed"
                animate="open"
                exit="closed"
                variants={mobileVariants}
                className={`lg:hidden fixed inset-y-0 right-0 h-[100dvh] w-screen max-w-none shadow-2xl z-[90] flex flex-col overflow-hidden ${
                  isDarkMode ? "bg-gray-900" : "bg-white"
                }`}
              >
                {/* Mobile Header */}
                <div className="sticky top-0 bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 p-5 sm:p-6 flex justify-between items-center z-10">
                  <div>
                    <h2 className="text-white font-bold text-xl sm:text-2xl">Menu</h2>
                    <p className="text-blue-100 text-xs sm:text-sm mt-1">ARC Computer Institute</p>
                  </div>
                  <motion.button
                    onClick={() => setIsOpen(false)}
                    className="text-white p-2 hover:bg-white/20 rounded-xl transition cursor-pointer"
                    whileHover={{ rotate: 90 }}
                  >
                    <FaTimes className="text-xl sm:text-2xl" />
                  </motion.button>
                </div>

                {/* Mobile Content */}
                <div className="flex-1 overflow-y-auto p-4 sm:p-6 space-y-2">
                  {navLinks.map((link) => {
                    const Icon = link.icon;
                    return (
                      <motion.div
                        key={link.name}
                        whileHover={{ x: 5 }}
                      >
                        <Link
                          to={link.path}
                          onClick={() => setIsOpen(false)}
                          className={`flex items-center gap-3 px-4 py-3 sm:py-4 rounded-xl transition-all cursor-pointer ${
                            isActive(link.path)
                              ? "bg-gradient-to-r from-blue-50 to-purple-50 text-blue-600 font-medium dark:bg-blue-900/30 dark:text-blue-400"
                              : isDarkMode 
                                ? "text-gray-300 hover:bg-gray-800/80" 
                                : "text-gray-700 hover:bg-gray-100/80"
                          }`}
                        >
                          <Icon className="text-lg sm:text-xl" />
                          <span className="text-sm sm:text-base">{link.name}</span>
                          {isActive(link.path) && (
                            <span className="ml-auto w-2 h-2 bg-blue-600 rounded-full" />
                          )}
                        </Link>
                      </motion.div>
                    );
                  })}

                  <div className="h-px bg-gradient-to-r from-transparent via-gray-300 dark:via-gray-700 to-transparent my-4" />

                  {/* Theme Toggle */}
                  <motion.button
                    onClick={toggleTheme}
                    className={`flex items-center gap-3 w-full px-4 py-3 sm:py-4 rounded-xl transition-all cursor-pointer ${
                      isDarkMode 
                        ? "text-gray-300 hover:bg-gray-800/80" 
                        : "text-gray-700 hover:bg-gray-100/80"
                    }`}
                    whileHover={{ x: 5 }}
                  >
                    {isDarkMode ? <FaSun className="text-lg sm:text-xl text-yellow-400" /> : <FaMoon className="text-lg sm:text-xl" />}
                    <span className="text-sm sm:text-base">{isDarkMode ? "Light Mode" : "Dark Mode"}</span>
                  </motion.button>

                  <div className="h-px bg-gradient-to-r from-transparent via-gray-300 dark:via-gray-700 to-transparent my-4" />

                  {/* Login/User Section */}
                  {isLoggedIn ? (
                    <div className={`p-4 sm:p-5 rounded-2xl ${isDarkMode ? "bg-gray-800/80 border border-gray-700" : "bg-gray-50/80 border border-gray-200"}`}>
                      <div className="flex items-center gap-3 mb-4">
                        <div className="w-12 h-12 sm:w-14 sm:h-14 bg-gradient-to-r from-green-500 to-green-600 rounded-full flex items-center justify-center text-white font-bold text-lg sm:text-xl shadow-lg">
                          {userName.charAt(0).toUpperCase()}
                        </div>
                        <div>
                          <p className={`font-semibold text-base sm:text-lg ${isDarkMode ? 'text-white' : 'text-gray-800'}`}>{userName}</p>
                          <p className={`text-xs sm:text-sm ${isDarkMode ? 'text-gray-400' : 'text-gray-500'}`}>✅ Logged In</p>
                        </div>
                      </div>
                      <button
                        onClick={() => {
                          handleLogout();
                          setIsOpen(false);
                        }}
                        className="w-full bg-gradient-to-r from-red-500 to-red-600 text-white py-3 sm:py-4 rounded-xl font-semibold text-sm sm:text-base hover:shadow-lg transition-all duration-300 cursor-pointer"
                      >
                        🚪 Logout
                      </button>
                    </div>
                  ) : (
                    <button
                      onClick={() => {
                        setShowLoginModal(true);
                        setIsOpen(false);
                      }}
                      className="flex items-center justify-center gap-2 w-full bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 text-white py-3 sm:py-4 rounded-xl font-semibold shadow-lg hover:shadow-xl text-sm sm:text-base cursor-pointer transition-all duration-300 hover:scale-[1.02]"
                    >
                      <FaSignInAlt className="text-base sm:text-lg" /> Student Login
                    </button>
                  )}

                  {/* Quick Info on Mobile */}
                  <div className={`mt-4 p-4 rounded-2xl ${isDarkMode ? "bg-gray-800/50" : "bg-gray-50/50"}`}>
                    <p className={`text-xs sm:text-sm font-semibold mb-3 ${isDarkMode ? 'text-white' : 'text-gray-800'}`}>📞 Quick Contact</p>
                    <div className="grid grid-cols-2 gap-2">
                      {quickLinks.slice(0, 4).map((item, index) => {
                        const Icon = item.icon;
                        return (
                          <div key={index} className={`flex items-center gap-2 p-2 rounded-lg ${isDarkMode ? "bg-gray-800" : "bg-white"}`}>
                            <Icon className={`${item.color} text-sm`} />
                            <span className={`text-xs ${isDarkMode ? 'text-gray-400' : 'text-gray-600'}`}>{item.value}</span>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                </div>
              </motion.div>
            </>
          )}
        </AnimatePresence>

      {/* Notification Toast */}
      <AnimatePresence>
        {showNotification && (
          <motion.div
            initial={{ opacity: 0, y: -50, scale: 0.9 }}
            animate={{ opacity: 1, y: 0, scale: 1 }}
            exit={{ opacity: 0, y: -50, scale: 0.9 }}
            className="fixed top-24 left-1/2 transform -translate-x-1/2 z-[100] bg-gradient-to-r from-green-500 to-emerald-500 text-white px-6 py-3 sm:px-8 sm:py-4 rounded-2xl shadow-2xl border border-white/20 backdrop-blur-sm"
          >
            <div className="flex items-center gap-3">
              <span className="text-2xl">🎉</span>
              <span className="font-semibold text-sm sm:text-base">{notificationMessage}</span>
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* Login Modal - Premium */}
      <AnimatePresence>
        {showLoginModal && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 bg-black/60 backdrop-blur-md z-[60] flex items-center justify-center p-3 sm:p-4"
            onClick={() => {
              setShowLoginModal(false);
              setLoginError("");
            }}
          >
            <motion.div
              ref={loginModalRef}
              initial={{ scale: 0.9, opacity: 0, y: 30 }}
              animate={{ scale: 1, opacity: 1, y: 0 }}
              exit={{ scale: 0.9, opacity: 0, y: 30 }}
              transition={{ type: "spring", stiffness: 300, damping: 30 }}
              className={`rounded-3xl shadow-2xl max-w-sm sm:max-w-md w-full overflow-hidden ${
                isDarkMode ? "bg-gray-900 border border-gray-700" : "bg-white"
              }`}
              onClick={(e) => e.stopPropagation()}
            >
              {/* Modal Header */}
              <div className="bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 p-6 sm:p-8 text-white">
                <div className="flex justify-between items-start">
                  <div>
                    <div className="flex items-center gap-3">
                      <div className="bg-white/20 rounded-xl p-2">
                        <FaUserGraduate className="text-2xl sm:text-3xl" />
                      </div>
                      <div>
                        <h2 className="text-2xl sm:text-3xl font-bold">Welcome Back!</h2>
                        <p className="text-blue-100 text-sm sm:text-base mt-1">Sign in to continue learning</p>
                      </div>
                    </div>
                  </div>
                  <button
                    onClick={() => {
                      setShowLoginModal(false);
                      setLoginError("");
                    }}
                    className="text-white hover:bg-white/20 p-2 rounded-xl transition cursor-pointer"
                  >
                    <FaTimesCircle className="text-xl sm:text-2xl" />
                  </button>
                </div>
              </div>

              {/* Modal Body */}
              <form onSubmit={handleLogin} className="p-6 sm:p-8">
                {loginError && (
                  <motion.div
                    initial={{ opacity: 0, y: -10 }}
                    animate={{ opacity: 1, y: 0 }}
                    className="mb-4 p-4 bg-red-50/80 border border-red-200 rounded-xl text-red-600 text-sm flex items-center gap-2"
                  >
                    <span className="text-lg">⚠️</span>
                    {loginError}
                  </motion.div>
                )}

                <div className="space-y-4">
                  <div>
                    <label className={`block text-sm font-medium mb-2 ${isDarkMode ? 'text-gray-300' : 'text-gray-700'}`}>
                      <FaUser className="inline mr-2 text-blue-600" />
                      Email Address
                    </label>
                    <input
                      type="email"
                      value={loginEmail}
                      onChange={(e) => setLoginEmail(e.target.value)}
                      className={`w-full px-4 py-3 border-2 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-500/30 focus:border-blue-500 transition text-sm sm:text-base ${
                        isDarkMode 
                          ? "bg-gray-800 border-gray-700 text-white focus:bg-gray-800" 
                          : "bg-white border-gray-200 text-gray-900 focus:bg-white"
                      }`}
                      placeholder="student@arc.com"
                      required
                    />
                  </div>

                  <div>
                    <label className={`block text-sm font-medium mb-2 ${isDarkMode ? 'text-gray-300' : 'text-gray-700'}`}>
                      <FaLock className="inline mr-2 text-blue-600" />
                      Password
                    </label>
                    <input
                      type="password"
                      value={loginPassword}
                      onChange={(e) => setLoginPassword(e.target.value)}
                      className={`w-full px-4 py-3 border-2 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-500/30 focus:border-blue-500 transition text-sm sm:text-base ${
                        isDarkMode 
                          ? "bg-gray-800 border-gray-700 text-white focus:bg-gray-800" 
                          : "bg-white border-gray-200 text-gray-900 focus:bg-white"
                      }`}
                      placeholder="••••••••"
                      required
                    />
                  </div>

                  <div className="flex items-center justify-between text-sm">
                    <label className={`flex items-center gap-2 ${isDarkMode ? 'text-gray-400' : 'text-gray-600'} cursor-pointer`}>
                      <input type="checkbox" className="rounded-lg text-blue-600 cursor-pointer" />
                      Remember me
                    </label>
                    <a href="#" className="text-blue-600 hover:text-blue-700 font-medium cursor-pointer">Forgot Password?</a>
                  </div>

                  <motion.button
                    type="submit"
                    whileHover={{ scale: 1.02 }}
                    whileTap={{ scale: 0.98 }}
                    className="w-full bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 text-white py-3.5 rounded-xl font-semibold shadow-lg hover:shadow-xl transition-all duration-300 text-sm sm:text-base cursor-pointer relative overflow-hidden group"
                  >
                    <span className="absolute inset-0 bg-gradient-to-r from-blue-600/0 via-white/20 to-purple-600/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700" />
                    <span className="relative z-10">🚀 Login to Dashboard</span>
                  </motion.button>

                  <div className="relative my-4">
                    <div className="absolute inset-0 flex items-center">
                      <div className={`w-full border-t ${isDarkMode ? 'border-gray-700' : 'border-gray-200'}`} />
                    </div>
                    <div className="relative flex justify-center text-xs sm:text-sm">
                      <span className={`px-4 ${isDarkMode ? 'bg-gray-900 text-gray-400' : 'bg-white text-gray-500'}`}>Demo Credentials</span>
                    </div>
                  </div>
                  <div className={`text-center text-xs sm:text-sm ${isDarkMode ? 'text-gray-500' : 'text-gray-500'} bg-gray-50 dark:bg-gray-800 p-3 rounded-xl`}>
                    <span className="font-mono">student@arc.com</span>
                    <span className="mx-2">/</span>
                    <span className="font-mono">student123</span>
                  </div>
                </div>
              </form>

              {/* Modal Footer */}
              <div className={`p-4 sm:p-6 border-t text-center ${isDarkMode ? "bg-gray-800/50 border-gray-700" : "bg-gray-50/50 border-gray-200"}`}>
                <p className={`text-sm sm:text-base ${isDarkMode ? 'text-gray-400' : 'text-gray-600'}`}>
                  New Student?{' '}
                  <Link
                    to="/contactSection"
                    onClick={() => setShowLoginModal(false)}
                    className="text-blue-600 font-semibold hover:text-blue-700 transition cursor-pointer"
                  >
                    🎓 Register Now
                  </Link>
                </p>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* Spacer */}
      <div className="h-[100px] sm:h-[108px] lg:h-[120px]" />
    </>
  );
};

export default Navbar;
